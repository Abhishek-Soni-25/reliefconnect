<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ReliefConnect - Connecting Heroes in Time of Crisis</title>
    <link rel="stylesheet" href="/css/home.css">
    <!-- Font Awesome or similar icon library would be needed for the icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
    <header>
        <div class="container">
            <nav>
                <div class="logo">
                    <a href="/">
                        <i class="fas fa-hands-helping"></i>
                        <span>ReliefConnect</span>
                    </a>
                </div>
                <ul class="nav-links">
                    <li><a href="/how-it-works">How it works</a></li>
                    <li><a href="/volunteer">Volunteer</a></li>
                    <li><a href="/resources">Resources</a></li>
                    <li><a href="/emergency-map">Emergency Map</a></li>
                    <li><a href="/contact">Contact</a></li>
                </ul>
                <div class="cta-button">
                    <a href="/get-started" class="btn primary-btn">Get Started</a>
                </div>
            </nav>
        </div>
    </header>

    <section class="hero">
        <div class="container">
            <div class="hero-content">
                <div class="hero-text">
                    <h1>Connecting Heroes in Time of Crisis</h1>
                    <p>Connect volunteers, NGOs, and resources during emergencies. Make a real difference when communities need it most.</p>
                    <div class="hero-buttons">
                        <a href="/signup_volunteer" class="btn primary-btn">Join as Volunteer</a>
                        <a href="/register" class="btn outline-btn">Register Organization</a>
                    </div>
                </div>
                <div class="hero-image">
                    <img src="/images/home.png" alt="Emergency response team">
                </div>
            </div>
        </div>
    </section>

    <section class="stats">
        <div class="container">
            <div class="stats-grid">
                <div class="stat-item">
                    <h2>10,000+</h2>
                    <p>Volunteers</p>
                </div>
                <div class="stat-item">
                    <h2>500+</h2>
                    <p>NGOs</p>
                </div>
                <div class="stat-item">
                    <h2>1,000+</h2>
                    <p>Emergencies Handled</p>
                </div>
                <div class="stat-item">
                    <h2>24/7</h2>
                    <p>Support</p>
                </div>
            </div>
        </div>
    </section>

    <section class="features">
        <div class="container">
            <h2>Powerful Features for Emergency Response</h2>
            <div class="features-grid">
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-asterisk"></i>
                    </div>
                    <h3>Real-time Coordination</h3>
                    <p>Instant communication and response coordination between teams</p>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-hand-holding-heart"></i>
                    </div>
                    <h3>Resource Matching</h3>
                    <p>Efficiently match resources with immediate needs</p>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-bullhorn"></i>
                    </div>
                    <h3>Emergency Alerts</h3>
                    <p>Quick dissemination of critical information</p>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3>Volunteer Management</h3>
                    <p>Streamlined volunteer registration and assignment</p>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h3>Resource Tracking</h3>
                    <p>Real-time monitoring of supplies and equipment</p>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-chart-bar"></i>
                    </div>
                    <h3>Impact Reports</h3>
                    <p>Comprehensive reporting and analytics</p>
                </div>
            </div>
        </div>
    </section>

    <section class="active-emergencies">
        <div class="container">
            <h2>Active Emergency Responses</h2>
            <div class="emergencies-grid">
                <div class="emergency-card">
                    <div class="emergency-header">
                        <h3>Flood Relief</h3>
                        <span class="badge urgent">Urgent</span>
                    </div>
                    <div class="emergency-details">
                        <p><i class="fas fa-map-marker-alt"></i> Central Valley, CA</p>
                        <p><i class="fas fa-box"></i> Water, Food, Shelter</p>
                        <p><i class="fas fa-users"></i> 234 Volunteers</p>
                    </div>
                </div>
                <div class="emergency-card">
                    <div class="emergency-header">
                        <h3>Wildfire Response</h3>
                        <span class="badge active">Active</span>
                    </div>
                    <div class="emergency-details">
                        <p><i class="fas fa-map-marker-alt"></i> Northern Region</p>
                        <p><i class="fas fa-box"></i> Medical, Transport</p>
                        <p><i class="fas fa-users"></i> 156 Volunteers</p>
                    </div>
                </div>
                <div class="emergency-card">
                    <div class="emergency-header">
                        <h3>Hurricane Recovery</h3>
                        <span class="badge ongoing">Ongoing</span>
                    </div>
                    <div class="emergency-details">
                        <p><i class="fas fa-map-marker-alt"></i> Coastal Area</p>
                        <p><i class="fas fa-box"></i> Construction, Supplies</p>
                        <p><i class="fas fa-users"></i> 389 Volunteers</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="cta">
        <div class="container">
            <h2>Ready to Make a Difference?</h2>
            <p>Join our network of emergency responders and help communities in need</p>
            <a href="/get-started" class="btn primary-btn">Get Started Now</a>
        </div>
    </section>

    <footer>
        <div class="container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <div class="logo">
                        <i class="fas fa-hands-helping"></i>
                        <span>ReliefConnect</span>
                    </div>
                    <p>Empowering communities through swift and efficient emergency response coordination.</p>
                </div>
                <div class="footer-links">
                    <h3>Quick Links</h3>
                    <ul>
                        <li><a href="/about">About Us</a></li>
                        <li><a href="/how-it-works">How It Works</a></li>
                        <li><a href="/resources">Resources</a></li>
                        <li><a href="/blog">Blog</a></li>
                    </ul>
                </div>
                <div class="footer-resources">
                    <h3>Resources</h3>
                    <ul>
                        <li><a href="/emergency-guide">Emergency Guide</a></li>
                        <li><a href="/training">Training Materials</a></li>
                        <li><a href="/partners">Partner Network</a></li>
                        <li><a href="/faq">FAQ</a></li>
                    </ul>
                </div>
                <div class="footer-contact">
                    <h3>Contact</h3>
                    <p>1234 Relief Street</p>
                    <p>Emergency Line: 888-555-0123</p>
                    <p>support@reliefconnect.org</p>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 ReliefConnect. All rights reserved.</p>
                <div class="social-icons">
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-linkedin-in"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                </div>
            </div>
        </div>
    </footer>
</body>
</html>